# Ruslan Desktop Agent — настройки

# --- LLM (Hermes — основной провайдер) ---
HERMES_API_URL=http://localhost:8080/v1
HERMES_API_KEY=your_key_here

# --- LLM (Ollama — fallback при недоступности Hermes) ---
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_FALLBACK=true

# --- Voice (STT + TTS) ---
# STT_MODEL=base
# TTS_ENGINE=system       # system (встроенный) или edge (онлайн)
# TTS_VOICE=              # "" = системный голос по умолчанию

# --- UI (PyQt5 оверлей) ---
# UI_ENABLED=true
# UI_SPRITE_SIZE=128
# UI_ALWAYS_ON_TOP=true
# UI_HOTKEY=cmd+shift+r   # macOS
# UI_HOTKEY=ctrl+shift+r  # Windows

# --- API (для плагинов) ---
# API_HOST=127.0.0.1
# API_PORT=8000

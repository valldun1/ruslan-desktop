# Ruslan Configuration
# Copy to .env and fill values

# === LLM / Hermes ===
HERMES_API_URL=http://localhost:8080/v1
HERMES_API_KEY=sk-your-key-here
HERMES_MODEL=hermes-3-opus

# === API ===
API_HOST=127.0.0.1
API_PORT=8000

# === Logging ===
LOG_LEVEL=DEBUG
LOG_FILE=logs/ruslan.log
LOG_JSON=false

# === Voice ===
STT_MODEL=base       # faster-whisper model size: tiny/base/small/medium/large
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
TTS_SPEAKER=default
WAKE_WORD=руслан

# === Windows Controller ===
DRY_RUN=false        # true = ничего не выполняет, только логирует
CONFIRM_DELETE=true
CONFIRM_EXECUTE=true
ENABLE_KEYBOARD=true

# === Character (Godot) ===
GODOT_WS_URL=ws://127.0.0.1:8100/character
CHARACTER_WIDTH=300
CHARACTER_HEIGHT=400

# === Memory ===
MEMORY_BACKEND=sqlite  # sqlite | postgres
SQLITE_PATH=data/ruslan.db
